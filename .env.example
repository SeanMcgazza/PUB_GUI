# ============================================================================
# BarTab — environment variables
# ============================================================================
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored; this template is the only env file committed to the repo.
#
# For local dev you can run with just the two NEXT_PUBLIC_SUPABASE_* vars in
# demo mode. Payments + check-in require the Stripe and secret vars below.
# ============================================================================

# --- Supabase --------------------------------------------------------------
# Project URL and the ANON (public) key. Safe to expose to the browser.
# Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key. SERVER ONLY — bypasses RLS. Used by the Stripe webhook and
# the /api/checkin + payment-intent routes to create/validate orders. NEVER
# expose this to the browser and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe ----------------------------------------------------------------
# Test-mode keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret from `stripe listen` (local) or the Dashboard webhook
# endpoint (deployed). Used to verify the raw webhook body.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Table session ---------------------------------------------------------
# Random string, >= 16 chars. Signs the short-lived HMAC "I scanned this table"
# cookie minted by /api/checkin and required by /api/stripe/payment-intent.
# Generate one, e.g.:  openssl rand -base64 32
TABLE_SESSION_SECRET=replace-with-a-long-random-secret

# --- App -------------------------------------------------------------------
# Absolute base URL of the app. Used to build Stripe Connect onboarding return
# URLs and table QR links. Set to your Vercel URL in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: force demo mode (no Supabase / Stripe, in-memory data) even when
# other vars are present. Leave unset for normal operation.
# NEXT_PUBLIC_DEMO_MODE=true
